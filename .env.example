# ALTER — Variables de entorno
# Copiá este archivo como .env y completá los valores

# Gemini API (Google AI Studio — gratuito para empezar)
# https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Upstash Redis (memoria persistente — plan gratuito disponible)
# https://console.upstash.com
UPSTASH_REDIS_URL=https://your-redis-instance.upstash.io
UPSTASH_REDIS_TOKEN=your_upstash_token_here

# Telegram Bot (para interactuar con ALTER desde el celular)
# Creá un bot con @BotFather en Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
# Tu chat ID — podés obtenerlo hablándole a @userinfobot
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# Google Custom Search (opcional — para el feed diario de noticias)
# https://developers.google.com/custom-search/v1/introduction
GOOGLE_SEARCH_API_KEY=your_google_search_api_key_here
GOOGLE_SEARCH_CX=your_custom_search_engine_id_here
